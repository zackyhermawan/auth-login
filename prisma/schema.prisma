generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is now configured in prisma.config.ts for Migrate and PrismaClient.
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Mahasiswa {
  id        Int      @id @default(autoincrement())
  npm       String   @unique
  nama      String
  createdAt DateTime @default(now())
}